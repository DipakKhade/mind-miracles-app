{
  "expo": {
    "name": "Mind Miracles",
    "slug": "mind-miracles-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/mm_images/app_icon.png",
    "scheme": "mindmiraclesapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dipak8999.mindmiraclesapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e3a5f",
        "foregroundImage": "./assets/mm_images/app_icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.dipak8999.mindmiraclesapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/mm_images/app_icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/mm_images/mind_miracles_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1e3a5f",
          "dark": {
            "backgroundColor": "#020617"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
