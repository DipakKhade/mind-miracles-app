{
  "expo": {
    "name": "Mind Miracles",
    "slug": "mind-miracles-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/mm_images/app_icon_v0.png",
    "scheme": "mindmiraclesapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dipak8999.mindmiraclesapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#166534",
        "foregroundImage": "./assets/mm_images/app_icon_v0.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.dipak8999.mindmiraclesapp"
    },
    "extra": {
      "googleWebClientId": "204929844187-h4dm7ld6esk5ugjtaa6r54455mo6f1jr.apps.googleusercontent.com"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/mm_images/flash_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#166534"
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}